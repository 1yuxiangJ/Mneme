# ============================================
# mneme — 占位符配置(用户回家自己填)
# 复制为 .env 后逐项替换 __YOUR_XXX__
# ============================================

# ----- DeepSeek (Awake + Sleep agent 用,用户有额度) -----
DEEPSEEK_API_KEY=__YOUR_DEEPSEEK_KEY__
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ----- Embedding (阿里通义 text-embedding-v3,DeepSeek 没有 embedding API) -----
# 申请:https://dashscope.console.aliyun.com/(国内付款,有免费额度,无需 VPN)
# 用 OpenAI-compatible 端口,LangChain OpenAIEmbeddings 直接接
EMBED_API_KEY=__YOUR_DASHSCOPE_KEY__
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL=text-embedding-v3
EMBED_DIMENSIONS=1024

# ----- PostgreSQL (本地装,用户回家做) -----
# brew install postgresql@17 && brew install pgvector
# createdb mneme && psql mneme -c "CREATE EXTENSION vector;"
DATABASE_URL=postgresql+asyncpg://userjyx:__YOUR_DB_PASSWORD__@localhost:5432/mneme

# ----- MCP Server -----
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8000
MCP_SERVER_PATH=/mcp

# ----- Sleep Agent 触发参数 -----
SLEEP_SCHEDULER_ENABLED=false       # true 才会自动 idle/cron 做梦
SLEEP_IDLE_THRESHOLD_SECONDS=1800   # 30 min 无 Awake 调用触发
SLEEP_DAILY_CRON_HOUR=3             # 凌晨 03:00 兜底
SLEEP_MAX_WALL_TIME_SECONDS=300     # 单次最多 5 min
SLEEP_MAX_TOKENS=50000              # 单次 token 上限
SLEEP_MIN_ARCHIVAL_COUNT=10         # 首次保护:archival 不足 10 条不跑
SLEEP_SWAP_LOCK_TIMEOUT_MS=500      # swap 拿不到表锁就快速失败,避免阻塞在线请求

# ----- Awake Agent 防卡死参数 -----
AWAKE_REACT_RECURSION_LIMIT=8       # ReAct 最多走 8 步
AWAKE_LLM_TIMEOUT_SECONDS=20        # 单次 LLM 调用超时
AWAKE_LLM_MAX_RETRIES=1             # LLM 调用最多重试 1 次
AWAKE_OVERALL_TIMEOUT_SECONDS=45    # 整个 Awake 请求兜底超时

# ----- Embedding cache -----
EMBEDDING_CACHE_SIZE=256            # 复用同文本 embedding,降低 remember 成本/延迟

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FILE=logs/mneme.log

# ----- User (MVP 单用户写死) -----
USER_ID=userjyx
